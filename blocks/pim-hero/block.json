{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "doo/pim-hero",
	"version": "1.0.0",
	"title": "Hero PIM",
	"category": "doo-blocks",
	"icon": "welcome-learn-more",
	"description": "Hero para el Programa de Innovación Municipal (PIM). Configurable con color navy.",
	"supports": { "html": false, "align": false, "multiple": false },
	"attributes": {
		"eyebrow":         { "type": "string", "default": "OFERTA FORMATIVA" },
		"title":           { "type": "string", "default": "Programa de Innovación Municipal" },
		"description":     { "type": "string", "default": "La FVMP se reserva el derecho de retirar del Plan PIM2026 aquellas acciones formativas que presenten una demanda muy elevada para optimizar el proceso de preinscripción." },
		"stat2Num":        { "type": "string", "default": "1.500+" },
		"stat2Label":      { "type": "string", "default": "plazas disponibles" },
		"stat3Num":        { "type": "string", "default": "3" },
		"stat3Label":      { "type": "string", "default": "modalidades" },
		"cardTitle":       { "type": "string", "default": "Preparando la oferta formativa para 2026" },
		"cardDescription": { "type": "string", "default": "Próximamente estará disponible el catálogo de cursos PIM2026. Es necesario iniciar sesión para inscribirse." },
		"cardButtonText":  { "type": "string", "default": "Iniciar sesión" },
		"cardButtonUrl":   { "type": "string", "default": "/iniciar-sesion/" },
		"cardRegisterText":{ "type": "string", "default": "¿No tienes cuenta? Regístrate →" },
		"cardRegisterUrl": { "type": "string", "default": "/registro/" }
	},
	"textdomain": "dw-tema",
	"editorScript": "doo-blocks-editor",
	"render": "file:./render.php"
}
