{
	"$schema": "https://schemas.wp.org/wp/6.9/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"useRootPaddingAwareAlignments": true,
		"layout": {
			"contentSize": "800px",
			"wideSize": "1440px"
		},
		"color": {
			"defaultDuotone": false,
			"defaultGradients": false,
			"defaultPalette": false,
			"palette": [
				{ "slug": "teal",      "color": "#00A9A5", "name": "Teal" },
				{ "slug": "orange",    "color": "#F5A623", "name": "Orange" },
				{ "slug": "red-cta",   "color": "#8B1F1F", "name": "Red CTA" },
				{ "slug": "navy",      "color": "#1A2B4A", "name": "Navy" },
				{ "slug": "bg-light",  "color": "#F0F0F0", "name": "Background Light" },
				{ "slug": "bg-med",    "color": "#F7F8FA", "name": "Background Medium" },
				{ "slug": "white",     "color": "#FFFFFF", "name": "White" },
				{ "slug": "text-body", "color": "#333333", "name": "Text Body" },
				{ "slug": "text-muted","color": "#666666", "name": "Text Muted" }
			]
		},
		"typography": {
			"defaultFontSizes": false,
			"fluid": false,
			"fontFamilies": [
				{
					"fontFamily": "'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif",
					"slug": "inter",
					"name": "Inter"
				}
			],
			"fontSizes": [
				{ "slug": "small",    "size": "0.875rem", "name": "Small - 14px" },
				{ "slug": "medium",   "size": "1rem",     "name": "Medium - 16px" },
				{ "slug": "large",    "size": "1.25rem",  "name": "Large - 20px" },
				{ "slug": "x-large",  "size": "1.5rem",   "name": "XL - 24px" },
				{ "slug": "xx-large", "size": "2.25rem",  "name": "2XL - 36px" },
				{ "slug": "hero",     "size": "3rem",     "name": "Hero - 48px" }
			]
		},
		"spacing": {
			"defaultSpacingSizes": false,
			"spacingSizes": [
				{ "slug": "10", "size": "0.25rem", "name": "4px" },
				{ "slug": "20", "size": "0.5rem",  "name": "8px" },
				{ "slug": "30", "size": "1rem",    "name": "16px" },
				{ "slug": "40", "size": "1.5rem",  "name": "24px" },
				{ "slug": "50", "size": "2rem",    "name": "32px" },
				{ "slug": "60", "size": "3rem",    "name": "48px" },
				{ "slug": "70", "size": "4rem",    "name": "64px" },
				{ "slug": "80", "size": "6rem",    "name": "96px" }
			]
		},
		"custom": {
			"lineHeight": {
				"tight": 1.2,
				"normal": 1.5,
				"relaxed": 1.75
			}
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--white)",
			"text": "var(--wp--preset--color--text-body)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--inter)",
			"fontSize": "var(--wp--preset--font-size--medium)",
			"lineHeight": "1.5"
		},
		"spacing": {
			"padding": {
				"top": "0",
				"right": "0",
				"bottom": "0",
				"left": "0"
			},
			"blockGap": "0"
		},
		"elements": {
			"heading": {
				"color": { "text": "var(--wp--preset--color--navy)" },
				"typography": { "fontWeight": "700", "lineHeight": "1.2" }
			},
			"h1": { "typography": { "fontSize": "var(--wp--preset--font-size--hero)" } },
			"h2": { "typography": { "fontSize": "var(--wp--preset--font-size--xx-large)" } },
			"h3": { "typography": { "fontSize": "var(--wp--preset--font-size--x-large)" } },
			"h4": { "typography": { "fontSize": "var(--wp--preset--font-size--large)" } },
			"link": {
				"color": { "text": "var(--wp--preset--color--teal)" },
				":hover": { "color": { "text": "var(--wp--preset--color--navy)" } }
			},
			"button": {
				"color": {
					"background": "var(--wp--preset--color--red-cta)",
					"text": "var(--wp--preset--color--white)"
				},
				"typography": { "fontWeight": "600", "fontSize": "var(--wp--preset--font-size--medium)" },
				"border": { "radius": "4px" },
				":hover": {
					"color": {
						"background": "var(--wp--preset--color--navy)",
						"text": "var(--wp--preset--color--white)"
					}
				}
			}
		},
		"blocks": {
			"core/navigation": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--inter)",
					"fontSize": "0.8125rem",
					"fontWeight": "400"
				},
				"color": { "text": "var(--wp--preset--color--text-body)" }
			},
			"core/site-title": {
				"typography": { "fontSize": "var(--wp--preset--font-size--large)", "fontWeight": "700" },
				"color": { "text": "var(--wp--preset--color--navy)" }
			},
			"core/quote": {
				"border": {
					"left": { "color": "var(--wp--preset--color--teal)", "width": "4px", "style": "solid" }
				}
			},
			"core/separator": {
				"color": { "background": "var(--wp--preset--color--bg-light)" }
			}
		}
	},
	"templateParts": [
		{ "name": "header", "title": "Header", "area": "header" },
		{ "name": "footer", "title": "Footer", "area": "footer" }
	],
	"customTemplates": [
		{ "name": "page-home",               "title": "Home",               "postTypes": ["page"] },
		{ "name": "page-formacion-continua", "title": "Formacion Continua", "postTypes": ["page"] },
		{ "name": "page-fap",                "title": "FAP",                "postTypes": ["page"] },
		{ "name": "page-pim",                "title": "PIM",                "postTypes": ["page"] }
	]
}
